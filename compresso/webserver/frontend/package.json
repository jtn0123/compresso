{
  "name": "compresso-frontend",
  "version": "0.0.1",
  "description": "Media library optimizer with approval workflow and compression dashboard",
  "productName": "Compresso",
  "author": "Josh.5 <jsunnex@gmail.com>",
  "license": "GPL-3.0-only",
  "private": true,
  "type": "module",
  "scripts": {
    "contract:generate": "openapi-typescript ../docs/api_schema_v2.json -o src/types/generated/api.ts",
    "contract:check": "openapi-typescript ../docs/api_schema_v2.json -o src/types/generated/api.ts --check",
    "postinstall": "quasar prepare --silent",
    "typecheck": "vue-tsc --noEmit",
    "typecheck:production": "node scripts/check-production-typescript.mjs",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore --ignore-path .prettierignore",
    "test": "vitest run",
    "test:watch": "vitest",
    "serve": "quasar dev --debug",
    "dev": "quasar dev",
    "build": "quasar build",
    "build:publish": "quasar build",
    "test:e2e": "npm run build:publish && playwright test",
    "test:e2e:run": "playwright test",
    "test:e2e:live": "npm run build:publish && playwright test --config=playwright.live.config.js",
    "test:e2e:live:run": "playwright test --config=playwright.live.config.js"
  },
  "dependencies": {
    "@quasar/extras": "^2.0.2",
    "axios": "^1.16.1",
    "chart.js": "^4.5.1",
    "core-js": "^3.49.0",
    "dompurify": "^3.4.5",
    "quasar": "^2.22.0",
    "remarkable": "^2.0.1",
    "remarkable-admonitions": "^0.2.2",
    "tiny-emitter": "^2.1.0",
    "vue": "^3.5.40",
    "vue-i18n": "^11.4.7",
    "vue-router": "^5.2.0",
    "vuedraggable": "^4.1.0",
    "xbbcode-parser": "^0.3.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@babel/eslint-parser": "^8.0.1",
    "@playwright/test": "^1.61.1",
    "@quasar/app-vite": "3.2.0",
    "@types/remarkable": "2.0.8",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/test-utils": "^2.4.10",
    "autoprefixer": "^10.5.4",
    "dotenv": "^17.4.2",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.10.0",
    "globals": "^17.6.0",
    "happy-dom": "^20.11.1",
    "jsdom": "^29.1.1",
    "openapi-typescript": "7.13.0",
    "prettier": "^3.9.6",
    "typescript": "7.0.2",
    "typescript-eslint": "8.65.0",
    "vitest": "^4.1.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "3.3.8"
  },
  "browserslist": [
    "last 10 Chrome versions",
    "last 10 Firefox versions",
    "last 4 Edge versions",
    "last 7 Safari versions",
    "last 8 Android versions",
    "last 8 ChromeAndroid versions",
    "last 8 FirefoxAndroid versions",
    "last 10 iOS versions",
    "last 5 Opera versions"
  ],
  "engines": {
    "node": "^24 || ^22",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "serialize-javascript": "^7.0.7",
    "vite": "7.3.6"
  }
}
